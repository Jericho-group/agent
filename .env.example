# ── LLM (OpenAI или любой OpenAI-совместимый провайдер) ──────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Если используешь OpenRouter:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ── Модели ────────────────────────────────────────────────────────────────────
ORCHESTRATOR_MODEL=gpt-4o
AGENT_MODEL=gpt-4o-mini
ROUTER_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── База данных PostgreSQL ────────────────────────────────────────────────────
# Вариант A: Supabase (hosted)
# Найти в: Supabase → Settings → Database → Connection string → Transaction pooler
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# Вариант B: Свой сервер (Docker PostgreSQL на VPS)
# SUPABASE_DB_URL=postgresql://chatbot_user:yourpassword@localhost:5432/chatbot_db
#
# Вариант C: Docker Compose (имя сервиса = postgres)
# SUPABASE_DB_URL=postgresql://chatbot_user:yourpassword@postgres:5432/chatbot_db

SUPABASE_DB_URL=postgresql://postgres:password@localhost:5432/chatbot_db

# Для Supabase Python SDK (Storage, Auth — опционально):
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Observability (LangFuse) ─────────────────────────────────────────────────
# https://cloud.langfuse.com или self-hosted: docker compose up -d
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Данные компании ───────────────────────────────────────────────────────────
COMPANY_NAME=My Company
APP_NAME=MyApp

# ── Отладка ───────────────────────────────────────────────────────────────────
DEBUG=false
